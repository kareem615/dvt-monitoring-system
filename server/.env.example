FIREBASE_DATABASE_URL=https://dvt-monitoring-system-default-rtdb.firebaseio.com

# Use exactly one service-account option.
FIREBASE_SERVICE_ACCOUNT_PATH=./serviceAccountKey.json
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account", "...":"..."}
# FIREBASE_SERVICE_ACCOUNT_BASE64=PASTE_BASE64_JSON_HERE

MODEL_PATH=./server/RandomForest.pkl
DVT_PERSISTENCE_SECONDS=10

ADMIN_EMAIL=admin@example.com
ADMIN_INITIAL_PASSWORD=ChangeMe#2026
ADMIN_NAME=DVT Admin

# Optional fallback if a patient has no linked doctor yet.
DEFAULT_ALERT_EMAIL=

# EmailJS free-plan settings.
EMAILJS_SERVICE_ID=
EMAILJS_TEMPLATE_ID=
EMAILJS_PUBLIC_KEY=
EMAILJS_PRIVATE_KEY=
